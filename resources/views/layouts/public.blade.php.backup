    <!-- ================= SCRIPTS ================= -->
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/page-flip@2.0.7/dist/js/page-flip.browser.js"></script>

    <script>
        // Speech Swiper Initialization
        const speechSwiper = new Swiper(".speechSwiper", {
            slidesPerView: 1,
            spaceBetween: 30,
            loop: true,
            autoplay: {
                delay: 6000,
                disable:Interaction: false,
            },
            navigation: {
                nextEl: ".speech-swiper-next",
                prevEl: ".speech-swiper-prev",
            },
            pagination: {
                el: ".speech-swiper-pagination",
                clickable: true,
            },
            effect: 'fade',
            fadeEffect: {
                crossFade: true
            },
        });

        // StPageFlip Flipbook Functionality
        let pageFlip = null;
        let pageImages = [];
        let flipbookModal = null;
        let flipbookContent = null;
        let flipbookTitle = null;
        let flipbookLoading = null;

        // Initialize modal elements after DOM is ready
        function initFlipbookModal() {
            flipbookModal = document.getElementById('flipbookModal');
            flipbookContent = document.getElementById('flipbookContent');
            flipbookTitle = document.getElementById('flipbookTitle');
            flipbookLoading = document.getElementById('flipbookLoading');
        }

        // Call initialization when DOM is ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initFlipbookModal);
        } else {
            initFlipbookModal();
        }

        function openFlipbook(pdfUrl, title) {
            flipbookTitle.textContent = title;
            flipbookModal.classList.remove('hidden');
            setTimeout(function() {
                flipbookModal.classList.remove('opacity-0');
                flipbookModal.classList.add('flex');
                flipbookContent.classList.remove('scale-95');
                flipbookContent.classList.add('scale-100');
            }, 10);
            document.body.style.overflow = 'hidden';

            // Initialize StPageFlip
            flipbookLoading.classList.remove('hidden');

            // Destroy existing flipbook if any
            if (pageFlip) {
                pageFlip.destroy();
                pageFlip = null;
                pageImages = [];
            }

            // Load PDF and convert to images for StPageFlip
            pdfjsLib.getDocument(pdfUrl).promise.then(function(pdf) {
                document.getElementById('totalPages').textContent = pdf.numPages;

                // Create pages for StPageFlip
                const flipbookContainer = document.getElementById('flipbook');
                flipbookContainer.innerHTML = '';

                let pagesPromises = [];
                for (let i = 1; i <= pdf.numPages; i++) {
                    pagesPromises.push(
                        pdf.getPage(i).then(function(page) {
                            let viewport = page.getViewport({scale: 1.5});
                            let canvas = document.createElement('canvas');
                            canvas.width = viewport.width;
                            canvas.height = viewport.height;
                            let ctx = canvas.getContext('2d');

                            return page.render({
                                canvasContext: ctx,
                                viewport: viewport
                            }).promise.then(function() {
                                return canvas.toDataURL();
                            });
                        })
                    );
                }

                Promise.all(pagesPromises).then(function(images) {
                    pageImages = images;

                    // Initialize StPageFlip with images
                    const flipbookContainer = document.getElementById('flipbook');
                    pageFlip = new St.PageFlip(flipbookContainer, {
                        width: 800,
                        height: 600,
                        size: 'stretch',
                        drawShadow: true,
                        flippingTime: 1000,
                        usePortrait: true,
                        startPage: 0,
                        autoSize: true,
                        maxShadowOpacity: 1,
                        showCover: true,
                        mobileScrollSupport: true
                    });

                    // Load pages from images
                    pageFlip.loadFromImages(pageImages);

                    // Listen to flip events
                    pageFlip.on('flip', function(e) {
                        document.getElementById('currentPage').textContent = e.data + 1;
                    });

                    flipbookLoading.classList.add('hidden');
                });
            }).catch(function(error) {
                console.error('Error loading PDF:', error);
                alert('Gagal memuat PDF. Silakan coba lagi.');
                closeFlipbook();
            });
        }

        function closeFlipbook() {
            flipbookModal.classList.add('opacity-0');
            flipbookContent.classList.remove('scale-100');
            flipbookContent.classList.add('scale-95');

            setTimeout(function() {
                flipbookModal.classList.add('hidden');
                flipbookModal.classList.remove('flex');
                if (pageFlip) {
                    pageFlip.destroy();
                    pageFlip = null;
                    pageImages = [];
                }
                document.body.style.overflow = 'auto';
            }, 300);
        }

        function turnPage(direction) {
            if (!pageFlip) return;

            if (direction === 'next') {
                pageFlip.flipNext('bottom');
            } else if (direction === 'prev') {
                pageFlip.flipPrev('bottom');
            }
        }

        function nextPage() {
            if (!pageFlip) return;
            pageFlip.flipNext('bottom');
        }

        function prevPage() {
            if (!pageFlip) return;
            pageFlip.flipPrev('bottom');
        }

        function zoomIn() {
            // StPageFlip doesn't have built-in zoom, this can be implemented with CSS transforms
            const flipbookContainer = document.getElementById('flipbook');
            const currentScale = flipbookContainer.style.transform.match(/scale\(([^)]+)\)/);
            const scale = currentScale ? parseFloat(currentScale[1]) : 1;
            flipbookContainer.style.transform = `scale(${scale * 1.1})`;
        }

        function zoomOut() {
            const flipbookContainer = document.getElementById('flipbook');
            const currentScale = flipbookContainer.style.transform.match(/scale\(([^)]+)\)/);
            const scale = currentScale ? parseFloat(currentScale[1]) : 1;
            flipbookContainer.style.transform = `scale(${scale * 0.9})`;
        }

        function resetZoom() {
            const flipbookContainer = document.getElementById('flipbook');
            flipbookContainer.style.transform = 'scale(1)';
        }

        // Global functions for onclick handlers
        window.turnPage = turnPage;
        window.nextPage = nextPage;
        window.prevPage = prevPage;
        window.zoomIn = zoomIn;
        window.zoomOut = zoomOut;
        window.resetZoom = resetZoom;
        window.openFlipbook = openFlipbook;
        window.closeFlipbook = closeFlipbook;

        // Close flip modal on click outside
        flipbookModal.addEventListener('click', function(e) {
            if (e.target === flipbookModal) {
                closeFlipbook();
            }
        });

        // Keyboard navigation
        document.addEventListener('keydown', function(e) {
            if (flipbookModal.classList.contains('hidden')) return;

            if (e.key === 'Escape') {
                closeFlipbook();
            } else if (e.key === 'ArrowLeft') {
                turnPage('prev');
            } else if (e.key === 'ArrowRight') {
                turnPage('next');
            } else if (e.key === '+' || e.key === '=') {
                zoomIn();
            } else if (e.key === '-' || e.key === '_') {
                zoomOut();
            }
        });
    </script>

</body>

</html>
